# App URL - set to your production domain for correct OAuth redirects
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Resend (for OTP emails)
# Get API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx
# Leave blank to use Resend sandbox (onboarding@resend.dev) — only delivers to your verified email
# Set to your verified domain sender for production: "FormBharat <noreply@yourdomain.com>"
RESEND_FROM_EMAIL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Database
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# AWS Configuration
# Production (Amplify): only set REGION_AWS - credentials come from the IAM execution role
REGION_AWS=ap-south-1

# AWS S3 (for image uploads in form builder)
S3_BUCKET_NAME=your-bucket-name
S3_PUBLIC_URL=https://your-bucket.s3.ap-south-1.amazonaws.com

# Local dev only: set these in .env.local (never commit real values)
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key

# MSG91 (for Phone OTP Verification field)
# Sign up at https://msg91.com → API → OTP
# Create an OTP template containing ##OTP## variable, get its template_id
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
# Without these set, OTP runs in dev mode: OTP is printed to server console

# Razorpay (for Payment / UPI fields)
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AWS Bedrock (for AI features)
# Uses same credentials as above - no additional config needed
# Current default: Llama 3 70B (no use case approval needed)
# Available models:
# - meta.llama3-70b-instruct-v1:0 (current default - instant approval)
# - anthropic.claude-3-haiku-20240307-v1:0 (requires use case - 20% cheaper)
# - anthropic.claude-3-5-sonnet-20240620-v1:0 (requires use case - best quality)
# - mistral.mistral-large-2402-v1:0 (instant approval - GDPR-friendly)
